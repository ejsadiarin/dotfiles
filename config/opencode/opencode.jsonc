{
    "$schema": "https://opencode.ai/config.json",
    // Approval workflow for tool usage
    // Options per tool: "allow", "ask", "deny"
    // Defaults: most tools are "allow", except doom_loop and external_directory which are "ask"
    // Use "*" for global default, then override specific tools
    "permission": {
        "*": "ask",
        "edit": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "bash": {
            "*": "allow",
            "rm *": "ask",
            "rmdir *": "ask",
            "git push *": "ask",
        },
        "skill": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "external_directory": "ask",
        "doom_loop": "ask",
    },
    // Custom instructions - loaded alongside AGENTS.md
    // Supports: file paths, glob patterns, URLs
    // Note: paths are relative to project root, use ~ for global config paths
    // "instructions": [
    //     "~/.config/opencode/rules/*.md"
    // ],
    "agent": {
        "code-reviewer": {
            "description": "Reviews code for best practices and potential issues",
            "mode": "subagent",
            "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
            "tools": {
                "write": false,
                "edit": false
            }
        },
    },
    "command": {},
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp"
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        }
    },
    "plugin": [
        "@tarquinen/opencode-dcp@latest",
    ],
    // "provider": {
    //     "router": {
    //         "npm": "@ai-sdk/openai-compatible",
    //         "name": "modelrelay",
    //         "options": {
    //             "baseURL": "http://127.0.0.1:7352/v1",
    //             "apiKey": "dummy-key"
    //         },
    //         "models": {
    //             "auto-fastest": {
    //                 "name": "Auto Fastest"
    //             }
    //         }
    //     },
    // },
    // "model": "router/auto-fastest",
}
